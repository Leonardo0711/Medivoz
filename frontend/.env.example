# Configuracion para desarrollo local (Medivoz v2)
# ================================================
# Copia este archivo como .env y completa los valores necesarios.

# Backend API base para llamadas REST
VITE_API_URL=http://localhost:4000/api/v1

# Backend base para Socket.IO (sin /api/v1)
VITE_API_BASE_URL=http://localhost:4000

# Observabilidad (opcional)
VITE_SENTRY_DSN=

# Notas:
# 1. No subas tu .env real al repositorio.
# 2. Las credenciales sensibles viven en el backend/VPS, no en el frontend.
